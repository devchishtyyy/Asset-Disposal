# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a long random string, e.g.:  openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── BTP Integration Suite Proxy ─────────────────────────────────────────────────
# Generic proxy endpoint for SAP ERP asset calls (uses ?action= routing)
BTP_PROXY_URL=https://devspace.test.apimanagement.eu10.hana.ondemand.com/asset/values
BTP_API_KEY=

# BTP Login iFlow — CPI runtime endpoints (direct POST, Basic Auth)
BTP_LOGIN_URL_DEV=https://integration-suite-q07hbh9w.it-cpi026-rt.cfapps.eu10-002.hana.ondemand.com/http/Login
BTP_LOGIN_URL_PRD=https://integration-suite-prd-ud55bnea.it-cpi026-rt.cfapps.eu10-002.hana.ondemand.com/http/Login

# BTP service binding credentials — format: client_id:client_secret
BTP_LOGIN_CREDENTIALS_DEV=your_dev_client_id:your_dev_client_secret
BTP_LOGIN_CREDENTIALS_PRD=your_prd_client_id:your_prd_client_secret

# ── Legacy SAP Configuration (Deprecated - Now handled by BTP) ──────────────────
# These are kept for reference only. All calls now go through BTP Integration Suite.
# SF_COMPANY_ID=packagesli
# SF_BASE_URL=https://api44.sapsf.com
# SAP_BASE_URL=https://vhpctds4ci.sap.packagesgroup.com:44300
# SAP_CLIENT=110
# SAP_MOCK=false

# ── Email (Nodemailer SMTP) ────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@packagesgroup.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="Asset Disposal System <noreply@packagesgroup.com>"
