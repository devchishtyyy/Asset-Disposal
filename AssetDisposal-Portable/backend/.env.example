# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate a long random string, e.g.:  openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── BTP Integration Suite Proxy ─────────────────────────────────────────────────
# Central proxy endpoint for all SAP and SuccessFactors API calls
# All SAP ERP, SAP SuccessFactors, and authentication requests are routed through this proxy
BTP_PROXY_URL=https://prdspace.prod01.apimanagement.eu10.hana.ondemand.com/10/assets
# Asset Detail OData endpoint used for single-entity reads
SAP_ASSET_ENDPOINT_URL=https://prdspace.prod01.apimanagement.eu10.hana.ondemand.com/10/assets/AssetDetailSet
SAP_ASSET_USERNAME=
SAP_ASSET_PASSWORD=
# API Key for BTP Integration Suite authentication (if required)
BTP_API_KEY=

# ── Legacy SAP Configuration (Deprecated - Now handled by BTP) ──────────────────
# These are kept for reference only. All calls now go through BTP Integration Suite.
# SF_COMPANY_ID=packagesli
# SF_BASE_URL=https://api44.sapsf.com
# SAP_BASE_URL=https://vhpctds4ci.sap.packagesgroup.com:44300
# SAP_CLIENT=110
# SAP_MOCK=false

# ── Email (Nodemailer SMTP) ────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@packagesgroup.com
SMTP_PASS=your_smtp_password
EMAIL_FROM="Asset Disposal System <noreply@packagesgroup.com>"
